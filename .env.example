# =====================================================
# paper-translate — 环境变量模板
# =====================================================
# 使用方法：
#   cp .env.example .env
#   vim .env   # 填入实际值
# 注意：.env 文件不应提交到 Git（已被 .gitignore 忽略）
# =====================================================

# =====================
# 应用环境
# =====================
ENVIRONMENT=production
APP_NAME=paper-translate
APP_VERSION=1.0.0
APP_DOMAIN=localhost

# =====================
# 数据库（PostgreSQL）
# =====================
POSTGRES_USER=paper_translate
POSTGRES_PASSWORD=please_change_me_in_production
POSTGRES_DB=paper_translate
POSTGRES_HOST=postgres
POSTGRES_PORT=5432
# 完整连接 URL（api / worker 容器内使用）
DATABASE_URL=postgresql+asyncpg://paper_translate:please_change_me_in_production@postgres:5432/paper_translate

# =====================
# Redis
# =====================
REDIS_HOST=redis
REDIS_PORT=6379
REDIS_DB=0
REDIS_PASSWORD=
REDIS_URL=redis://redis:6379/0

# =====================
# JWT 鉴权
# =====================
# 生成命令：python -c "import secrets; print(secrets.token_urlsafe(64))"
JWT_SECRET_KEY=please_change_me_to_a_random_64_char_string_in_production
JWT_ALGORITHM=HS256
JWT_ACCESS_TOKEN_EXPIRE_MINUTES=1440

# =====================
# 阿里云 OSS（对象存储）
# =====================
# 用于存储用户上传的 PDF 与生成的译文
OSS_ACCESS_KEY_ID=your_oss_access_key_id
OSS_ACCESS_KEY_SECRET=your_oss_access_key_secret
OSS_ENDPOINT=oss-cn-hangzhou.aliyuncs.com
OSS_BUCKET=paper-translate-pdfs
OSS_REGION=cn-hangzhou
# 签名 URL 过期时间（秒），24h = 86400
OSS_SIGNED_URL_EXPIRE=86400
# 24h 自动清理规则（OSS 控制台也要配置）
OSS_LIFECYCLE_DAYS=1

# 腾讯云 COS（可选，备用）
# COS_SECRET_ID=
# COS_SECRET_KEY=
# COS_REGION=
# COS_BUCKET=

# =====================
# LLM API（DeepSeek / GLM-4 / OpenAI 等）
# =====================
# DeepSeek
DEEPSEEK_API_KEY=your_deepseek_api_key
DEEPSEEK_BASE_URL=https://api.deepseek.com/v1
DEEPSEEK_MODEL=deepseek-chat

# GLM-4（智谱，备用）
GLM_API_KEY=your_glm_api_key
GLM_BASE_URL=https://open.bigmodel.cn/api/paas/v4
GLM_MODEL=glm-4-flash

# OpenAI（备用）
OPENAI_API_KEY=
OPENAI_BASE_URL=https://api.openai.com/v1
OPENAI_MODEL=gpt-4o-mini

# 默认使用的 LLM 服务（deepseek / glm / openai）
DEFAULT_LLM_SERVICE=deepseek

# 单次 LLM 调用最大 token（防刷）
LLM_MAX_TOKENS_PER_CALL=8000
# 每日 LLM 成本上限（元），超限触发告警
LLM_DAILY_COST_LIMIT_CNY=50.0

# =====================
# 短信服务（阿里云 / 腾讯云）
# =====================
# 阿里云短信
SMS_PROVIDER=aliyun
ALIYUN_SMS_ACCESS_KEY_ID=your_access_key_id
ALIYUN_SMS_ACCESS_KEY_SECRET=your_access_key_secret
ALIYUN_SMS_SIGN_NAME=PaperTranslate
ALIYUN_SMS_TEMPLATE_CODE=SMS_xxxxxxx

# 腾讯云短信（备用）
# TENCENT_SMS_SECRET_ID=
# TENCENT_SMS_SECRET_KEY=
# TENCENT_SMS_APP_ID=
# TENCENT_SMS_TEMPLATE_ID=

# 验证码有效期（秒）
SMS_CODE_EXPIRE_SECONDS=300

# =====================
# 邮件服务（用于注册验证 / 找回密码 / 告警）
# =====================
SMTP_HOST=smtp.example.com
SMTP_PORT=465
SMTP_USE_SSL=true
SMTP_USERNAME=noreply@example.com
SMTP_PASSWORD=your_smtp_password
SMTP_FROM_EMAIL=noreply@example.com
SMTP_FROM_NAME=Paper Translate

# =====================
# 支付（微信 / 支付宝）
# =====================
# 微信支付 Native
WECHAT_PAY_ENABLED=false
WECHAT_APP_ID=
WECHAT_MCH_ID=
WECHAT_API_KEY=
WECHAT_NOTIFY_URL=https://yourdomain.com/api/v1/orders/wechat/callback

# 支付宝当面付
ALIPAY_ENABLED=false
ALIPAY_APP_ID=
ALIPAY_PRIVATE_KEY_PATH=/app/secrets/alipay_private_key.pem
ALIPAY_PUBLIC_KEY_PATH=/app/secrets/alipay_public_key.pem
ALIPAY_NOTIFY_URL=https://yourdomain.com/api/v1/orders/alipay/callback

# =====================
# 文件上传限制
# =====================
# 单个 PDF 最大体积（字节），默认 50MB
MAX_UPLOAD_SIZE_BYTES=52428800
# 单个 PDF 最大页数
MAX_PDF_PAGES=100
# 文件 24h 自动清理
FILE_TTL_HOURS=24

# =====================
# 翻译配额
# =====================
# 免费档
QUOTA_FREE_DAILY_PAGES=5
QUOTA_FREE_MONTHLY_PAGES=30
# 标准档
QUOTA_STANDARD_MONTHLY_PAGES=200
QUOTA_STANDARD_PRICE_CNY=29
# Pro 档
QUOTA_PRO_MONTHLY_PAGES=800
QUOTA_PRO_PRICE_CNY=69

# =====================
# CORS
# =====================
# 前端域名（开发与生产）
CORS_ORIGINS=http://localhost,http://localhost:80,http://localhost:5173,https://yourdomain.com

# =====================
# Sentry（错误监控）
# =====================
SENTRY_DSN=
SENTRY_ENVIRONMENT=production
SENTRY_TRACES_SAMPLE_RATE=0.1

# =====================
# 日志
# =====================
LOG_LEVEL=INFO
LOG_FORMAT=json

# =====================
# 监控
# =====================
# Prometheus 指标路径
METRICS_PATH=/metrics
# 健康检查路径
HEALTH_CHECK_PATH=/api/v1/health

# =====================
# 告警 Webhook
# =====================
# 企业微信机器人（接收 LLM 成本超限告警）
WECOM_WEBHOOK_URL=
WECOM_WEBHOOK_MENTIONED_MOBILE=

# =====================
# 翻译核心配置
# =====================
# 翻译引擎：pdf2zh_next / babeldoc
TRANSLATION_ENGINE=pdf2zh_next
# 跳过 References 章节
SKIP_REFERENCES=true
# 章节识别 LLM 调用开关
ENABLE_SECTION_DETECTION=true
# 章节识别最大 token
SECTION_DETECTION_MAX_TOKENS=1000

# =====================
# 开发环境专用
# =====================
# 设为 true 启用 SQL echo（生产务必关闭）
SQL_ECHO=false
# 设为 true 启用 Dramatiq --watch 自动重载（生产务必关闭）
DRAMATIQ_WATCH=false
# 设为 true 跳过 OSS 上传（仅本地调试用）
MOCK_OSS=false
ENVIRONMENT=production
APP_NAME=paper-translate
APP_VERSION=1.0.0
APP_DOMAIN=REQUIRED

POSTGRES_USER=paper_translate
POSTGRES_PASSWORD=CHANGE_ME
POSTGRES_DB=paper_translate
POSTGRES_HOST=postgres
POSTGRES_PORT=5432
DATABASE_URL=postgresql+asyncpg://paper_translate:CHANGE_ME@postgres:5432/paper_translate

REDIS_HOST=redis
REDIS_PORT=6379
REDIS_DB=0
REDIS_PASSWORD=
REDIS_URL=redis://redis:6379/0

JWT_SECRET_KEY=CHANGE_ME
JWT_ALGORITHM=HS256
JWT_ACCESS_TOKEN_EXPIRE_MINUTES=1440

OSS_ACCESS_KEY_ID=REQUIRED
OSS_ACCESS_KEY_SECRET=REQUIRED
OSS_ENDPOINT=oss-cn-hangzhou.aliyuncs.com
OSS_BUCKET=paper-translate-pdfs
OSS_REGION=cn-hangzhou
OSS_SIGNED_URL_EXPIRE=86400
OSS_LIFECYCLE_DAYS=1

DEEPSEEK_API_KEY=REQUIRED
DEEPSEEK_BASE_URL=https://api.deepseek.com/v1
DEEPSEEK_MODEL=deepseek-chat

GLM_API_KEY=REQUIRED
GLM_BASE_URL=https://open.bigmodel.cn/api/paas/v4
GLM_MODEL=glm-4-flash

OPENAI_API_KEY=
OPENAI_BASE_URL=https://api.openai.com/v1
OPENAI_MODEL=gpt-4o-mini

DEFAULT_LLM_SERVICE=deepseek
LLM_MAX_TOKENS_PER_CALL=8000
LLM_DAILY_COST_LIMIT_CNY=50.0

SMS_PROVIDER=aliyun
ALIYUN_SMS_ACCESS_KEY_ID=REQUIRED
ALIYUN_SMS_ACCESS_KEY_SECRET=REQUIRED
ALIYUN_SMS_SIGN_NAME=PaperTranslate
ALIYUN_SMS_TEMPLATE_CODE=REQUIRED
SMS_CODE_EXPIRE_SECONDS=300

SMTP_HOST=REQUIRED
SMTP_PORT=465
SMTP_USE_SSL=true
SMTP_USERNAME=REQUIRED
SMTP_PASSWORD=REQUIRED
SMTP_FROM_EMAIL=REQUIRED
SMTP_FROM_NAME=Paper Translate

WECHAT_PAY_ENABLED=false
WECHAT_APP_ID=
WECHAT_MCH_ID=
WECHAT_API_KEY=
WECHAT_NOTIFY_URL=https://REQUIRED/api/v1/orders/wechat/callback

ALIPAY_ENABLED=false
ALIPAY_APP_ID=
ALIPAY_PRIVATE_KEY_PATH=/app/secrets/alipay_private_key.pem
ALIPAY_PUBLIC_KEY_PATH=/app/secrets/alipay_public_key.pem
ALIPAY_NOTIFY_URL=https://REQUIRED/api/v1/orders/alipay/callback

MAX_UPLOAD_SIZE_BYTES=52428800
MAX_PDF_PAGES=100
FILE_TTL_HOURS=24

QUOTA_FREE_DAILY_PAGES=5
QUOTA_FREE_MONTHLY_PAGES=30
QUOTA_STANDARD_MONTHLY_PAGES=200
QUOTA_STANDARD_PRICE_CNY=29
QUOTA_PRO_MONTHLY_PAGES=800
QUOTA_PRO_PRICE_CNY=69

CORS_ORIGINS=http://localhost,http://localhost:80,https://REQUIRED

SENTRY_DSN=REQUIRED
SENTRY_ENVIRONMENT=production
SENTRY_TRACES_SAMPLE_RATE=0.1

LOG_LEVEL=WARNING
LOG_FORMAT=json
DEBUG=false

METRICS_PATH=/metrics
HEALTH_CHECK_PATH=/api/v1/health

WECOM_WEBHOOK_URL=
WECOM_WEBHOOK_MENTIONED_MOBILE=

TRANSLATION_ENGINE=pdf2zh_next
SKIP_REFERENCES=true
ENABLE_SECTION_DETECTION=true
SECTION_DETECTION_MAX_TOKENS=1000

SQL_ECHO=false
DRAMATIQ_WATCH=false
MOCK_OSS=false

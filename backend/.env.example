# =====================================================
# paper-translate — backend/.env.example
# =====================================================
# 复制为 .env 后填入真实值
# 与根目录 .env.example 配套使用；本文件仅描述后端运行时关心的变量
# =====================================================

# App
APP_ENV=development
DEBUG=false
APP_VERSION=0.1.0
APP_NAME=paper-translate

# Database
# 默认 SQLite（开发）：DATABASE_URL=sqlite+aiosqlite:///./paper_translate.db
# PostgreSQL（生产）：postgresql+asyncpg://user:pass@host:5432/db
DATABASE_URL=sqlite+aiosqlite:///./paper_translate.db
DATABASE_ECHO=false
DATABASE_POOL_SIZE=10
DATABASE_MAX_OVERFLOW=20

# Redis
REDIS_URL=redis://localhost:6379/0
REDIS_MAX_CONNECTIONS=50

# JWT
JWT_SECRET=please_change_me_to_a_random_64_char_string_in_production
JWT_ALGORITHM=HS256
JWT_EXPIRE_MINUTES=1440
JWT_ISSUER=paper-translate

# Aliyun OSS
OSS_ACCESS_KEY_ID=
OSS_ACCESS_KEY_SECRET=
OSS_ENDPOINT=oss-cn-hangzhou.aliyuncs.com
OSS_BUCKET=paper-translate-pdfs
OSS_REGION=cn-hangzhou
OSS_SIGNED_URL_EXPIRE=86400
OSS_LIFECYCLE_DAYS=1

# LLM
LLM_DEFAULT_SERVICE=deepseek
LLM_MAX_TOKENS_PER_CALL=8000
LLM_DAILY_COST_LIMIT_CNY=50.0
DEEPSEEK_API_KEY=
DEEPSEEK_BASE_URL=https://api.deepseek.com/v1
DEEPSEEK_MODEL=deepseek-chat
GLM_API_KEY=
GLM_BASE_URL=https://open.bigmodel.cn/api/paas/v4
GLM_MODEL=glm-4-flash
OPENAI_API_KEY=
OPENAI_BASE_URL=https://api.openai.com/v1
OPENAI_MODEL=gpt-4o-mini

# WeChat Pay
WECHAT_PAY_ENABLED=false
WECHAT_APP_ID=
WECHAT_MCH_ID=
WECHAT_API_KEY=
WECHAT_NOTIFY_URL=

# Alipay
ALIPAY_ENABLED=false
ALIPAY_APP_ID=
ALIPAY_PRIVATE_KEY_PATH=/app/secrets/alipay_private_key.pem
ALIPAY_PUBLIC_KEY_PATH=/app/secrets/alipay_public_key.pem
ALIPAY_NOTIFY_URL=

# SMS
SMS_PROVIDER=mock
SMS_ACCESS_KEY_ID=
SMS_ACCESS_KEY_SECRET=
SMS_SIGN_NAME=PaperTranslate
SMS_TEMPLATE_CODE=
SMS_CODE_EXPIRE_SECONDS=300

# Upload limits
UPLOAD_MAX_SIZE=52428800
UPLOAD_MAX_PAGES=100
UPLOAD_TMP_DIR=/tmp/paper-translate/uploads

# HIDDEN-FEATURE: Markdown / Word 导出开关(默认 false)
# 详见 HIDDEN_FEATURES.md
ENABLE_MARKDOWN_EXPORT=false
ENABLE_DOCX_EXPORT=false

# CORS
ALLOWED_ORIGINS=http://localhost,http://localhost:5173,http://localhost:80

# Sentry
SENTRY_DSN=
SENTRY_ENVIRONMENT=development
SENTRY_TRACES_SAMPLE_RATE=0.1

# Logging
LOG_LEVEL=INFO
LOG_FORMAT=json

# WeCom
WECOM_WEBHOOK_URL=
WECOM_WEBHOOK_MENTIONED_MOBILE=

# SMTP (邮件验证码 / 通知)
SMTP_HOST=
SMTP_PORT=587
SMTP_USE_TLS=true
SMTP_USERNAME=
SMTP_PASSWORD=
SMTP_FROM_EMAIL=
SMTP_FROM_NAME=Paper Translate

# 验证码
VERIFY_CODE_EXPIRE_SECONDS=300
VERIFY_CODE_LENGTH=6
VERIFY_CODE_DEV_VALUE=123456
